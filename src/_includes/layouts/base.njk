<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{% if title %}{{ title }} · {% endif %}{{ site.title }}</title>
    <meta name="description" content="{{ description or site.description }}" />
    <link rel="stylesheet" href="/assets/css/styles.css" />
  </head>
  <body{% if bodyClass %} class="{{ bodyClass }}"{% endif %}>
    <header class="header">
      <div class="header-inner">
        <div>
          <a class="brand" href="/">{{ site.author }}</a>
        </div>
        <nav class="nav" aria-label="Primary">
          {% for item in nav %}
            {% set current = page.url == item.href %}
            <a href="{{ item.href }}" {% if current %}aria-current="page"{% endif %}>{{ item.label }}</a>
          {% endfor %}
        </nav>
      </div>
    </header>

    <main class="main">
      <div class="container">
        {{ content | safe }}
      </div>
    </main>

    <footer class="footer">
      <div class="container">
        <div class="small">
          © {{ site.author }}.
          <span class="footer-links">
            <a href="https://open.spotify.com/album/7BuPIlz3BY5ft8gAXZtCTS?si=p7xVvVbqQ9SRMw0Exb_sYw">Spotify</a>
            <span aria-hidden="true">·</span>
            <a href="https://www.instagram.com/charlotteoconnor_music/">Instagram</a>
            <span aria-hidden="true">·</span>
            <a href="https://www.tiktok.com/@charlotteoconnor_music">TikTok</a>
            <span aria-hidden="true">·</span>
            <a href="mailto:info@charlotteoconnor.music">Enquiries</a>
            <span aria-hidden="true">·</span>
            <a href="mailto:me@charlotteoconnor.music">Personal</a>
          </span>
        </div>
      </div>
    </footer>
  </body>
</html>
