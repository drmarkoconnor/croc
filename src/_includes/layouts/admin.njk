<!doctype html>
<html lang="en" data-admin-page="{{ adminPage }}">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{% if title %}{{ title }} · {% endif %}Admin · {{ site.title }}</title>
    <meta name="robots" content="noindex,nofollow" />
    <link rel="stylesheet" href="/assets/css/styles.css" />
  </head>
  <body>
    <header class="header">
      <div class="header-inner">
        <div>
          <a class="brand" href="/">{{ site.author }}</a>
          <div class="small">Admin</div>
        </div>
        <nav class="nav" aria-label="Admin">
          <a href="/admin/dashboard/">Dashboard</a>
          <a href="/admin/projects/">Projects</a>
          <a href="/admin/practice-log/">Practice log</a>
          <button class="button" type="button" data-logout style="margin-left:1rem;">Log out</button>
        </nav>
      </div>
    </header>

    <main class="main">
      <div class="container">
        {{ content | safe }}
      </div>
    </main>

    <script type="module" src="/assets/js/adminAuth.js"></script>
  </body>
</html>
